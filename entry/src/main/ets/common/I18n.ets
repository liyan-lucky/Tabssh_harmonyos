export class I18n {
  static t(language: string, key: string): string {
    const table: Record<string, string> = resolveEffectiveLanguage(language) === LANG_EN ? EN_TEXT : ZH_TEXT;
    if (table[key] !== undefined) {
      return table[key];
    }
    if (ZH_TEXT[key] !== undefined) {
      return ZH_TEXT[key];
    }
    return key;
  }
}
